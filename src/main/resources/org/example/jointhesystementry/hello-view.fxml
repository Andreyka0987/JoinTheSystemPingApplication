<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="312.0" prefWidth="455.0" spacing="20.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.jointhesystementry.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
      <AnchorPane prefHeight="350.0" prefWidth="443.0">
         <children>
            <Button fx:id="pingButton" layoutX="14.0" layoutY="221.0" mnemonicParsing="false" onAction="#pingStream" prefHeight="37.0" prefWidth="94.0" text="Ping" />
            <Button fx:id="enterStreamButton" layoutX="14.0" layoutY="174.0" mnemonicParsing="false" onAction="#enterStream" prefHeight="37.0" prefWidth="94.0" text="Enter stream" />
            <Label fx:id="streamStatus" layoutX="161.0" layoutY="22.0" prefHeight="17.0" prefWidth="94.0" text="Stream is offline" />
            <RadioButton fx:id="pingRadioButton" layoutX="314.0" layoutY="231.0" mnemonicParsing="false" onAction="#isStreamCheckerOn" text="PingStream" />
            <Label fx:id="enterStreamStatusLabel" layoutX="135.0" layoutY="77.0" prefHeight="17.0" prefWidth="146.0" />
            <RadioButton fx:id="isYouTubeRadio" layoutX="314.0" layoutY="193.0" mnemonicParsing="false" text="YouTube " onAction="#isYoTubeOn" />
         </children>
      </AnchorPane>
   </children>
</VBox>
